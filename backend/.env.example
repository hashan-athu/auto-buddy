# Copy to backend/.env for local development. Do NOT commit the real .env.

# Generate a real one for production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC

# Leave unset to use the local SQLite file (backend/db.sqlite3).
# For Postgres:
#   DATABASE_URL=postgres://user:password@localhost:5432/auto_buddy
# DATABASE_URL=

# Frontend dev origin(s) allowed to call the API / submit forms.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
